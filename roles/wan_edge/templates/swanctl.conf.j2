# purpose: strongSwan swanctl configuration for route-based IPsec
# generated by: hybridops.network.wan_edge
# maintainer: HybridOps.Tech

connections {
{% for tunnel in wan_edge_tunnels %}
  wan_{{ tunnel.name }} {
    version = 2

    local_addrs  = {{ tunnel.local_public_ip | default(wan_edge_public_local_ip) }}
    remote_addrs = {{ tunnel.peer_public_ip | default(wan_edge_public_peer_ip) }}

    proposals   = {{ wan_edge_ipsec.proposals }}
    dpd_delay   = {{ wan_edge_ipsec.dpd_delay }}
    dpd_timeout = {{ wan_edge_ipsec.dpd_timeout }}

    local {
      auth = psk
      id   = {{ tunnel.local_public_ip | default(wan_edge_public_local_ip) }}
    }

    remote {
      auth = psk
      id   = {{ tunnel.peer_public_ip | default(wan_edge_public_peer_ip) }}
    }

    children {
      wan_{{ tunnel.name }} {
        esp_proposals = {{ wan_edge_ipsec.esp_proposals }}
{% if wan_edge_bgp_transit | bool %}
        local_ts  = {{ tunnel.inside_local | ansible.utils.ipaddr('network/prefix') }},{{ wan_edge_loopbacks | join(',') }},{{ wan_edge_bgp.advertise | join(',') }},{{ wan_edge_bgp.import_allow | join(',') }}
        remote_ts = {{ tunnel.inside_peer }}/32,{{ wan_edge_bgp.import_allow | join(',') }}
{% else %}
        local_ts  = {{ tunnel.inside_local | ansible.utils.ipaddr('network/prefix') }},{{ wan_edge_loopbacks | join(',') }},{{ wan_edge_bgp.advertise | join(',') }}
        remote_ts = {{ tunnel.inside_peer }}/32,{{ wan_edge_bgp.import_allow | join(',') }}
{% endif %}

        start_action = {{ tunnel.start_action | default(wan_edge_ipsec.start_action) | default('start') }}
        close_action = {{ tunnel.close_action | default(wan_edge_ipsec.close_action) | default('restart') }}
        dpd_action   = {{ tunnel.dpd_action | default(wan_edge_ipsec.dpd_action) | default('restart') }}

        mark_in  = {{ tunnel.mark | default(tunnel.key) }}
        mark_out = {{ tunnel.mark | default(tunnel.key) }}
        reqid    = {{ tunnel.key }}
        policies = yes
      }
    }
  }
{% endfor %}
}

secrets {
{% for tunnel in wan_edge_tunnels %}
{% set tunnel_psk = wan_edge_ipsec_psk_map.get(tunnel.name, tunnel.psk | default(wan_edge_ipsec.psk)) %}
  ike_psk_{{ tunnel.name }} {
    id-1 = {{ tunnel.local_public_ip | default(wan_edge_public_local_ip) }}
    id-2 = {{ tunnel.peer_public_ip | default(wan_edge_public_peer_ip) }}
    secret = "{{ tunnel_psk }}"
  }
{% endfor %}
}
