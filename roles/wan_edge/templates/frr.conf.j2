# purpose: FRR BGP config for WAN edge/hub
# generated by: hybridops.network.wan_edge
# maintainer: HybridOps.Tech

frr defaults traditional
hostname {{ inventory_hostname }}
service integrated-vtysh-config
log syslog informational

{% set seq = namespace(v=10) -%}
ip prefix-list PL-OUT seq {{ seq.v }} permit {{ (wan_edge_bgp.export_allow | first) if (wan_edge_bgp.export_allow | length > 0) else '0.0.0.0/32' }}
{% for prefix in (wan_edge_bgp.export_allow[1:] if (wan_edge_bgp.export_allow | length > 1) else []) %}
{% set seq.v = seq.v + 10 -%}
ip prefix-list PL-OUT seq {{ seq.v }} permit {{ prefix }}
{% endfor %}
{% set seq.v = seq.v + 90 -%}
ip prefix-list PL-OUT seq {{ seq.v }} deny 0.0.0.0/0 le 32

{% set seq2 = namespace(v=10) -%}
ip prefix-list PL-IN seq {{ seq2.v }} permit {{ (wan_edge_bgp.import_allow | first) if (wan_edge_bgp.import_allow | length > 0) else '0.0.0.0/32' }}
{% for prefix in (wan_edge_bgp.import_allow[1:] if (wan_edge_bgp.import_allow | length > 1) else []) %}
{% set seq2.v = seq2.v + 10 -%}
ip prefix-list PL-IN seq {{ seq2.v }} permit {{ prefix }}
{% endfor %}
{% set seq2.v = seq2.v + 90 -%}
ip prefix-list PL-IN seq {{ seq2.v }} deny 0.0.0.0/0 le 32

router bgp {{ wan_edge_bgp.local_as }}
 bgp router-id {{ wan_edge_bgp.router_id }}
 no bgp ebgp-requires-policy

{% if wan_edge_bgp.peer_groups | default([]) | length > 0 %}
{% for peer_group in wan_edge_bgp.peer_groups %}
 neighbor {{ peer_group.name }} peer-group
 neighbor {{ peer_group.name }} remote-as {{ peer_group.remote_as }}
 neighbor {{ peer_group.name }} disable-connected-check
 neighbor {{ peer_group.name }} ebgp-multihop 2
{% for neighbor in peer_group.neighbors %}
 neighbor {{ neighbor }} peer-group {{ peer_group.name }}
{% endfor %}
{% endfor %}

 address-family ipv4 unicast
{% for network in wan_edge_bgp.advertise %}
  network {{ network }}
{% endfor %}
{% for peer_group in wan_edge_bgp.peer_groups %}
  neighbor {{ peer_group.name }} prefix-list PL-IN in
  neighbor {{ peer_group.name }} prefix-list PL-OUT out
  neighbor {{ peer_group.name }} soft-reconfiguration inbound
{% endfor %}
 exit-address-family
{% else %}
 neighbor WAN peer-group
 neighbor WAN remote-as {{ wan_edge_bgp.peer_as }}
 neighbor WAN disable-connected-check
 neighbor WAN ebgp-multihop 2

{% for neighbor in wan_edge_bgp.neighbors %}
 neighbor {{ neighbor }} peer-group WAN
{% endfor %}

 address-family ipv4 unicast
{% for network in wan_edge_bgp.advertise %}
  network {{ network }}
{% endfor %}
  neighbor WAN prefix-list PL-IN in
  neighbor WAN prefix-list PL-OUT out
  neighbor WAN soft-reconfiguration inbound
 exit-address-family
{% endif %}
